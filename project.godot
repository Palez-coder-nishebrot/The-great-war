"Prov_saver": ""
}

[application]

config/name="The great war (1905 - 1930)"
run/main_scene="res://Scenes/Menu/Menu.tscn"
config/icon="res://icon.png"

[autoload]

Players="*res://Objects/Global/Players.gd"
GlobalMarket="*res://Objects/Global/GlobalMarket.gd"
Functions="*res://Objects/Global/Functions.gd"
Research="*res://Objects/Global/Research.gd"
Units="*res://Objects/Global/Units.gd"
Reforms="*res://Objects/Global/Reforms.gd"

[display]

window/size/width=1920
window/size/height=1080
window/dpi/allow_hidpi=true
window/stretch/mode="2d"

[global]

mouse=false

