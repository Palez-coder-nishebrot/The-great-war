; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Resource",
"class": "Prov_saver",
"language": "GDScript",
"path": "res://Objects/Provinces/Paths_of_provinces.gd"
} ]
